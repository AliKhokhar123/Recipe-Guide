RewriteEngine On

# 1. Access admin panel via /admin
# Points to the dashboard, which redirects to login.php if not authenticated
RewriteRule ^admin/?$ admin/dashboard.php [L]

# 2. Access home via /index
RewriteRule ^index/?$ index.php [L]

# 3. Support for extensionless PHP files (e.g., /about -> about.php)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^\.]+)$ $1.php [NC,L]
